{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "coree-inject-session",
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.12.0 inject --type session"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "coree-inject-prompt",
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.12.0 inject --type prompt --budget 8000"
          }
        ]
      }
    ]
  }
}
