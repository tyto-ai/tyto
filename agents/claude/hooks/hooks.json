{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.9.5 inject --type session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.9.5 inject --type prompt --budget 8000"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.9.5 inject --type stop"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes @coree-ai/coree@0.9.5 inject --type compact"
          }
        ]
      }
    ]
  }
}
