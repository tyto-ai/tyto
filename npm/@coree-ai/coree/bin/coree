#!/usr/bin/env node
'use strict';

const path = require('path');
const fs = require('fs');
const { spawnSync } = require('child_process');
const { platform, arch, env } = process;

const PLATFORMS = {
  'linux-x64':    '@coree-ai/coree-linux-x64/coree',
  'linux-arm64':  '@coree-ai/coree-linux-arm64/coree',
  'darwin-arm64': '@coree-ai/coree-darwin-arm64/coree',
  'win32-x64':    '@coree-ai/coree-win32-x64/coree.exe',
};

// Claude Code installs plugin deps into a separate npm-cache dir rather than a node_modules
// sibling of the plugin cache, so require.resolve fails with standard paths. When
// CLAUDE_PLUGIN_ROOT is set we walk up from it to find the npm-cache and add it to the
// search path so resolution works in both npx and Claude Code plugin contexts.
function getClaudeNpmCacheDir() {
  if (!env.CLAUDE_PLUGIN_ROOT) return null;
  let dir = env.CLAUDE_PLUGIN_ROOT;
  while (true) {
    const candidate = path.join(dir, 'npm-cache');
    if (fs.existsSync(path.join(candidate, 'node_modules'))) return candidate;
    const parent = path.dirname(dir);
    if (parent === dir) return null;
    dir = parent;
  }
}

const claudeNpmCache = getClaudeNpmCacheDir();

function selectBin() {
  if (env.COREE_BINARY_OVERRIDE) {
    process.stderr.write(`coree: using binary override: ${env.COREE_BINARY_OVERRIDE}\n`);
    return env.COREE_BINARY_OVERRIDE;
  }
  const key = `${platform}-${arch}`;
  const pkg = PLATFORMS[key];
  if (!pkg) {
    process.stderr.write(`coree: unsupported platform: ${platform} ${arch}\n`);
    process.exit(1);
  }
  const searchPaths = [path.join(__dirname, '..')];
  if (claudeNpmCache) searchPaths.push(claudeNpmCache);
  try {
    return require.resolve(pkg, { paths: searchPaths });
  } catch {
    process.stderr.write(`coree: platform binary not installed: ${pkg}\n`);
    process.stderr.write('Try reinstalling @coree-ai/coree.\n');
    process.exit(1);
  }
}

function findModelDir() {
  const modelPkg = '@coree-ai/coree-model-bge-small-en-v1.5/package.json';
  const searchPaths = [path.join(__dirname, '..')];
  if (claudeNpmCache) searchPaths.push(claudeNpmCache);
  for (const p of searchPaths) {
    try {
      return path.join(path.dirname(require.resolve(modelPkg, { paths: [p] })), 'model');
    } catch {}
  }
  return null;
}

const bin = selectBin();
const childEnv = { ...env };

const modelDir = findModelDir();
if (modelDir) childEnv.COREE_MODEL_DIR = modelDir;

// Codex: preserve project root from PWD (Node.js does not reset PWD like shells do).
if (!childEnv.COREE__PROJECT_ROOT && childEnv.PWD && childEnv.PWD !== process.cwd()) {
  childEnv.COREE__PROJECT_ROOT = childEnv.PWD;
}

const result = spawnSync(bin, process.argv.slice(2), {
  stdio: 'inherit',
  shell: false,
  env: childEnv,
});

if (result.error) throw result.error;
process.exitCode = result.status ?? 1;
